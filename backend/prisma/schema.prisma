generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ─────────────────────────────────────────────────

enum Role {
  ROOT
  ADMIN
  BASE
}

enum AccountType {
  MAIN
  SUB
}

enum NotificationType {
  REMINDER
  MILESTONE
  ALERT
  ADMIN
  SYSTEM
}

// ─── User ──────────────────────────────────────────────────

model User {
  id                   String    @id @default(cuid())
  name                 String
  email                String    @unique
  username             String    @unique
  passwordHash         String
  role                 Role      @default(BASE)
  language             String    @default("it")
  currency             String    @default("EUR")
  avatarUrl            String?
  emailVerified        Boolean   @default(false)
  emailVerifyToken     String?   @unique
  passwordResetToken   String?   @unique
  passwordResetExpires DateTime?
  isActive             Boolean   @default(true)
  lastSeenVersion      String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  accounts           Account[]
  incomeSources      IncomeSource[]
  entries            MonthlyEntry[]
  inviteCodesCreated InviteCode[]       @relation("InviteCreatedBy")
  inviteCodeUsed     InviteCode?        @relation("InviteUsedBy")
  notifications      Notification[]
  pushSubscriptions  PushSubscription[]

  @@map("users")
}

// ─── Account ───────────────────────────────────────────────

model Account {
  id        String      @id @default(cuid())
  userId    String
  name      String
  type      AccountType @default(MAIN)
  icon      String?
  iconUrl   String?     @map("icon_url")
  color     String?
  isActive  Boolean     @default(true)
  sortOrder Int         @default(0)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  balances EntryBalance[]

  @@unique([userId, name])
  @@index([userId])
  @@map("accounts")
}

// ─── Income Source ─────────────────────────────────────────

model IncomeSource {
  id        String   @id @default(cuid())
  userId    String
  name      String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user    User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  incomes EntryIncome[]

  @@unique([userId, name])
  @@index([userId])
  @@map("income_sources")
}

// ─── Monthly Entry ─────────────────────────────────────────

model MonthlyEntry {
  id        String   @id @default(cuid())
  userId    String
  date      DateTime @db.Date
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  balances EntryBalance[]
  incomes  EntryIncome[]

  @@index([userId, date])
  @@map("monthly_entries")
}

// ─── Entry Balance ─────────────────────────────────────────

model EntryBalance {
  id        String  @id @default(cuid())
  entryId   String
  accountId String
  amount    Decimal @db.Decimal(12, 2)

  entry   MonthlyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  account Account      @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([entryId, accountId])
  @@map("entry_balances")
}

// ─── Entry Income ──────────────────────────────────────────

model EntryIncome {
  id             String  @id @default(cuid())
  entryId        String
  incomeSourceId String
  amount         Decimal @db.Decimal(12, 2)

  entry        MonthlyEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  incomeSource IncomeSource @relation(fields: [incomeSourceId], references: [id], onDelete: Cascade)

  @@unique([entryId, incomeSourceId])
  @@map("entry_incomes")
}

// ─── Invite Code ───────────────────────────────────────────

model InviteCode {
  id              String    @id @default(cuid())
  code            String    @unique
  createdByUserId String
  usedByUserId    String?   @unique
  isActive        Boolean   @default(true)
  createdAt       DateTime  @default(now())
  usedAt          DateTime?

  createdBy User  @relation("InviteCreatedBy", fields: [createdByUserId], references: [id])
  usedBy    User? @relation("InviteUsedBy", fields: [usedByUserId], references: [id])

  @@map("invite_codes")
}

// ─── Notification ──────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@map("notifications")
}

// ─── Push Subscription ─────────────────────────────────────

model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  endpoint  String   @unique
  p256dh    String
  auth      String
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("push_subscriptions")
}

// ─── Backup Log ────────────────────────────────────────────

enum BackupStatus {
  RUNNING
  COMPLETED
  FAILED
}

model BackupLog {
  id          String       @id @default(cuid())
  filename    String
  sizeBytes   Int          @default(0)
  status      BackupStatus @default(RUNNING)
  error       String?
  triggeredBy String?      // userId or "scheduler"
  createdAt   DateTime     @default(now())
  completedAt DateTime?

  @@index([createdAt])
  @@map("backup_logs")
}
