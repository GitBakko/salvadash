{
  "apps": [
    {
      "name": "salvadash-api",
      "script": "dist/index.js",
      "cwd": ".",
      "node_args": "--env-file=.env",
      "instances": 1,
      "exec_mode": "fork",
      "env": {
        "NODE_ENV": "production",
        "API_PORT": "3000"
      },
      "max_memory_restart": "300M",
      "log_date_format": "YYYY-MM-DD HH:mm:ss Z",
      "error_file": "./logs/pm2-error.log",
      "out_file": "./logs/pm2-out.log",
      "merge_logs": true,
      "autorestart": true,
      "watch": false
    }
  ]
}
