# ─── Database ───────────────────────────────────────────────
DATABASE_URL="postgresql://salvadash:salvadash_dev@localhost:5432/salvadash?schema=public"

# ─── JWT ────────────────────────────────────────────────────
JWT_ACCESS_SECRET="your-access-secret-change-me-in-production"
JWT_REFRESH_SECRET="your-refresh-secret-change-me-in-production"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─── SMTP ───────────────────────────────────────────────────
SMTP_HOST="smtp.office365.com"
SMTP_PORT=587
SMTP_USER="your-email@example.com"
SMTP_PASS="your-smtp-password"
SMTP_SECURE=false
SMTP_FROM="your-email@example.com"
SMTP_FROM_NAME="SalvaDash"

# ─── App ────────────────────────────────────────────────────
APP_URL="http://localhost:5173"
API_URL="http://localhost:3000"
API_PORT=3000
NODE_ENV="development"

# ─── VAPID (Web Push) ──────────────────────────────────────
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
VAPID_SUBJECT="mailto:your-email@example.com"

# ─── Seed ───────────────────────────────────────────────────
SEED_ROOT_NAME="Root"
SEED_ROOT_EMAIL="root@example.com"
SEED_ROOT_USERNAME="root"
SEED_ROOT_PASSWORD="change-me-root-password"

SEED_BAKKO_NAME="Bakko"
SEED_BAKKO_EMAIL="bakko@example.com"
SEED_BAKKO_USERNAME="bakko"
SEED_BAKKO_PASSWORD="change-me-bakko-password"

SEED_EXCEL_PATH="./prisma/data/Risparmi.xlsx"

# ─── Backup ─────────────────────────────────────────────────
BACKUP_DIR="./backups"
BACKUP_RETENTION_DAYS=10
BACKUP_CLOUD_ENABLED=false
# BACKUP_S3_ENDPOINT=""
# BACKUP_S3_BUCKET=""
# BACKUP_S3_ACCESS_KEY=""
# BACKUP_S3_SECRET_KEY=""

# Brandfetch API (logo search) — https://developers.brandfetch.com
BRANDFETCH_API_KEY=""
